{
  "name": "qqbot-gateway",
  "version": "1.0.0",
  "description": "Standalone QQ Bot Gateway service with HTTP API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc -p client/tsconfig.json",
    "start": "node dist/index.js",
    "start:client": "node dist/client/index.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/node-ws": "^1.0.0",
    "hono": "^4.12.12",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
